{% extends 'base.html.twig' %}

{% block title %}Sign Up - Lumeo AI{% endblock %}

{% block body %}
<div class="min-h-screen w-full bg-[#fcfcfc] flex items-center justify-center font-sans text-zinc-900 py-10">
    <div class="w-full max-w-[400px] bg-white p-8 rounded-[20px] shadow-[0_4px_24px_rgba(0,0,0,0.03)] border border-zinc-200/80">
        
        <div class="flex justify-center mb-6">
            <div class="w-12 h-12 bg-zinc-900 rounded-full flex items-center justify-center shadow-sm">
                <svg class="w-6 h-6 text-zinc-100" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <g stroke-width="2" stroke-linecap="butt">
                        <line x1="12" y1="3" x2="12" y2="7"></line>
                        <line x1="12" y1="17" x2="12" y2="21"></line>
                        <line x1="12" y1="3" x2="12" y2="7" transform="rotate(30 12 12)"></line>
                        <line x1="12" y1="17" x2="12" y2="21" transform="rotate(30 12 12)"></line>
                        <line x1="12" y1="3" x2="12" y2="7" transform="rotate(60 12 12)"></line>
                        <line x1="12" y1="17" x2="12" y2="21" transform="rotate(60 12 12)"></line>
                        <line x1="12" y1="3" x2="12" y2="7" transform="rotate(90 12 12)"></line>
                        <line x1="12" y1="17" x2="12" y2="21" transform="rotate(90 12 12)"></line>
                    </g>
                </svg>
            </div>
        </div>

        <h1 class="text-[24px] font-medium text-center text-[#18181b] mb-6">Create an Account</h1>

        <form action="#" class="flex flex-col gap-4">
            <div>
                <label class="block text-[13px] font-medium text-zinc-700 mb-1.5">Full Name</label>
                <input type="text" placeholder="Jane Doe" class="w-full px-4 py-2.5 bg-[#fcfcfc] border border-zinc-200 rounded-[10px] text-[14px] outline-none focus:border-[#a855f7] focus:ring-1 focus:ring-[#a855f7] transition-all">
            </div>

            <div>
                <label class="block text-[13px] font-medium text-zinc-700 mb-1.5">Email Address</label>
                <input type="email" placeholder="you@example.com" class="w-full px-4 py-2.5 bg-[#fcfcfc] border border-zinc-200 rounded-[10px] text-[14px] outline-none focus:border-[#a855f7] focus:ring-1 focus:ring-[#a855f7] transition-all">
            </div>
            
            <div>
                <label class="block text-[13px] font-medium text-zinc-700 mb-1.5">Password</label>
                <input type="password" placeholder="••••••••" class="w-full px-4 py-2.5 bg-[#fcfcfc] border border-zinc-200 rounded-[10px] text-[14px] outline-none focus:border-[#a855f7] focus:ring-1 focus:ring-[#a855f7] transition-all">
            </div>

            <button type="button" class="w-full py-2.5 mt-2 bg-[#18181b] text-white text-[14px] font-medium rounded-[10px] hover:bg-black transition-colors text-center block">
                Sign Up
            </button>
        </form>

        <p class="text-center text-[13px] text-zinc-500 mt-6">
            Already have an account? 
            <a href="{{ path('app_login') }}" class="text-[#a855f7] hover:underline">Log in</a>
        </p>
    </div>
</div>
{% endblock %}
