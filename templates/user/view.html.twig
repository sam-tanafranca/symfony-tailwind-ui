{% extends 'layout/admin.html.twig' %}

{% block title %}User Profile: {{ user.fullName }} - Lumeo AI{% endblock %}

{% block content %}
<div class="px-8 py-8 w-full max-w-[900px] mx-auto">
    
    <!-- Breadcrumb & Actions Header -->
    <div class="flex items-center justify-between mb-8 pb-6 border-b border-zinc-100">
        <div>
            <div class="flex items-center gap-1.5 text-[13px] text-zinc-500 mb-2.5">
                <a href="{{ path('app_user_index') }}" class="hover:text-zinc-800 transition-colors">Users</a>
                <span>&rsaquo;</span>
                <span class="text-zinc-800 font-medium">{{ user.fullName }}</span>
            </div>
            <h1 class="text-[28px] font-semibold text-zinc-900 tracking-tight leading-none">{{ user.fullName }}</h1>
        </div>

        <div class="flex items-center gap-3">
            <a href="{{ path('app_user_edit', {id: user.id}) }}" class="flex items-center gap-1.5 px-4 py-2 bg-white rounded-[10px] text-[13px] font-medium text-zinc-700 border border-zinc-200/80 shadow-sm hover:bg-zinc-50 transition-colors">
                <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                Edit Profile
            </a>

            <!-- Delete Form with CSRF -->
            <form method="post" action="{{ path('app_user_delete', {id: user.id}) }}" onsubmit="return confirm('Are you absolutely sure you want to delete this user? This action cannot be undone.');" class="inline-block">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                <button type="submit" class="flex items-center gap-1.5 px-4 py-2 bg-rose-50 text-rose-700 border border-rose-100 rounded-[10px] text-[13px] font-medium hover:bg-rose-100 transition-colors shadow-sm cursor-pointer">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    Delete User
                </button>
            </form>
        </div>
    </div>

    <!-- Flash Messages (specifically for error feedback on this page if any) -->
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-6 p-4 rounded-[12px] text-[14px] font-medium flex items-center gap-2.5 {% if label == 'success' %}bg-emerald-50 text-emerald-800 border border-emerald-100{% else %}bg-rose-50 text-rose-800 border border-rose-100{% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <!-- Info Sections Grid -->
    <div class="grid grid-cols-3 gap-6">
        
        <!-- Left Column: Personal and Credentials -->
        <div class="col-span-2 flex flex-col gap-6">
            
            <!-- Personal and Credentials Card -->
            <div class="bg-white border border-zinc-200/80 rounded-[16px] shadow-[0_4px_24px_rgba(0,0,0,0.02)] p-6">
                <h2 class="text-[16px] font-semibold text-zinc-900 mb-4 pb-2 border-b border-zinc-50">Profile Specifications</h2>
                
                <dl class="grid grid-cols-2 gap-x-6 gap-y-4 text-[13.5px]">
                    <div>
                        <dt class="text-zinc-400 font-medium mb-0.5">First Name</dt>
                        <dd class="text-zinc-900 font-medium">{{ user.firstName }}</dd>
                    </div>
                    <div>
                        <dt class="text-zinc-400 font-medium mb-0.5">Last Name</dt>
                        <dd class="text-zinc-900 font-medium">{{ user.lastName }}</dd>
                    </div>
                    <div>
                        <dt class="text-zinc-400 font-medium mb-0.5">Email Address</dt>
                        <dd class="text-zinc-900 font-medium">{{ user.email }}</dd>
                    </div>
                    <div>
                        <dt class="text-zinc-400 font-medium mb-0.5">Old System Reference ID</dt>
                        <dd class="text-zinc-900 font-mono">{% if user.oldSysId %}{{ user.oldSysId }}{% else %}<span class="text-zinc-300">N/A</span>{% endif %}</dd>
                    </div>
                    <div>
                        <dt class="text-zinc-400 font-medium mb-0.5">Username Identifier</dt>
                        <dd class="text-zinc-900 font-mono">@{{ user.username }}</dd>
                    </div>
                    <div>
                        <dt class="text-zinc-400 font-medium mb-0.5">Global Status</dt>
                        <dd class="mt-1">
                            {% if user.isActive %}
                                <span class="inline-flex items-center gap-1.5 text-[11px] font-semibold text-emerald-700 bg-emerald-50 px-2.5 py-0.5 rounded-full">
                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Active / Enabled
                                </span>
                            {% else %}
                                <span class="inline-flex items-center gap-1.5 text-[11px] font-semibold text-zinc-500 bg-zinc-50 px-2.5 py-0.5 rounded-full border border-zinc-200">
                                    <span class="w-1.5 h-1.5 rounded-full bg-zinc-400"></span> Inactive / Disabled
                                </span>
                            {% endif %}
                        </dd>
                    </div>
                </dl>
            </div>

            <!-- Access Privileges Switch Checkers -->
            <div class="bg-white border border-zinc-200/80 rounded-[16px] shadow-[0_4px_24px_rgba(0,0,0,0.02)] p-6">
                <h2 class="text-[16px] font-semibold text-zinc-900 mb-4 pb-2 border-b border-zinc-50">Data Access Privileges</h2>
                
                <div class="grid grid-cols-2 gap-4">
                    {% set scopes = {
                        'Company Records': user.isAccessAllCompany,
                        'Branches Locations': user.isAccessAllBranch,
                        'Business Units': user.isAccessAllBU,
                        'Divisions': user.isAccessAllDivision,
                        'Departments': user.isAccessAllDept,
                        'Department Units': user.isAccessAllDeptUnit,
                        'Employee Types': user.isAccessAllEmpType
                    } %}
                    
                    {% for label, granted in scopes %}
                        <div class="flex items-center justify-between p-3.5 bg-[#fcfcfc] border border-zinc-100 rounded-[12px]">
                            <span class="text-[13.5px] font-medium text-zinc-800">{{ label }}</span>
                            <div class="flex items-center">
                                {% if granted %}
                                    <span class="inline-flex items-center gap-1 text-[11.5px] font-semibold text-purple-700 bg-purple-50 px-2.5 py-0.5 rounded-full border border-purple-100">
                                        All Access
                                    </span>
                                {% else %}
                                    <span class="inline-flex items-center gap-1 text-[11.5px] font-semibold text-zinc-500 bg-zinc-50 px-2.5 py-0.5 rounded-full border border-zinc-200">
                                        Restricted
                                    </span>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>

        </div>

        <!-- Right Column: Security Roles and Meta -->
        <div class="flex flex-col gap-6">
            
            <!-- Roles Card -->
            <div class="bg-white border border-zinc-200/80 rounded-[16px] shadow-[0_4px_24px_rgba(0,0,0,0.02)] p-6">
                <h2 class="text-[15px] font-semibold text-zinc-900 mb-3.5 pb-2 border-b border-zinc-50">System Roles</h2>
                <div class="flex flex-col gap-1.5">
                    {% for role in user.roles %}
                        <span class="inline-block text-[12px] px-3 py-1 rounded-md font-medium bg-zinc-50 border border-zinc-200 text-zinc-700 w-full text-center">
                            {{ role }}
                        </span>
                    {% else %}
                        <span class="text-[13px] text-zinc-400 italic">No system roles assigned.</span>
                    {% endfor %}
                </div>
            </div>

            <!-- Allowed Roles Card -->
            <div class="bg-white border border-zinc-200/80 rounded-[16px] shadow-[0_4px_24px_rgba(0,0,0,0.02)] p-6">
                <h2 class="text-[15px] font-semibold text-zinc-900 mb-3.5 pb-2 border-b border-zinc-50">Allowed Roles</h2>
                <div class="flex flex-wrap gap-1.5">
                    {% for role in user.rolesAllowed %}
                        <span class="text-[11.5px] px-2.5 py-0.5 rounded-full font-medium bg-purple-50 text-purple-700 border border-purple-100">
                            {{ role }}
                        </span>
                    {% else %}
                        <span class="text-[13px] text-zinc-400 italic">No allowed roles assigned.</span>
                    {% endfor %}
                </div>
            </div>

            <!-- Types Card -->
            <div class="bg-white border border-zinc-200/80 rounded-[16px] shadow-[0_4px_24px_rgba(0,0,0,0.02)] p-6">
                <h2 class="text-[15px] font-semibold text-zinc-900 mb-3.5 pb-2 border-b border-zinc-50">Classification Types</h2>
                <div class="flex flex-wrap gap-1.5">
                    {% for type in user.types %}
                        <span class="text-[11.5px] px-2.5 py-0.5 rounded-full font-medium bg-blue-50 text-blue-700 border border-blue-100">
                            {{ type|capitalize }}
                        </span>
                    {% else %}
                        <span class="text-[13px] text-zinc-400 italic">No classification types assigned.</span>
                    {% endfor %}
                </div>
            </div>

        </div>

    </div>
</div>
{% endblock %}
