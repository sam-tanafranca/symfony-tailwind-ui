{% extends 'base.html.twig' %}

{% block body %}
<div class="h-screen w-full bg-white flex font-sans overflow-hidden text-zinc-900">
    
    <!-- Sidebar component -->
    {{ include('components/_sidebar.html.twig') }}

    <!-- Main Content -->
    <main class="flex-1 flex flex-col relative h-full min-w-0">
        
        <!-- Header component -->
        {{ include('components/_header.html.twig') }}

        <!-- Center Content Body -->
        <div class="flex-1 overflow-y-auto">
            {% block content %}{% endblock %}
        </div>

    </main>
</div>
{% endblock %}
