{% extends 'base.html.twig' %}

{% block title %}Lumeo AI Assistant{% endblock %}

{% block body %}
<div class="h-screen w-full bg-white flex font-sans overflow-hidden text-zinc-900">
    
    <!-- Sidebar -->
    <aside class="w-[72px] bg-[#fcfcfc] flex flex-col items-center py-6 border-r border-zinc-100/80 z-10 shrink-0">
        <!-- Logo -->
        <div class="w-8 h-8 bg-zinc-900 rounded-full flex items-center justify-center mb-6 shrink-0 shadow-sm">
            <svg class="w-5 h-5 text-zinc-100" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <g stroke-width="2" stroke-linecap="butt">
                    <line x1="12" y1="3" x2="12" y2="7"></line>
                    <line x1="12" y1="17" x2="12" y2="21"></line>
                    <line x1="12" y1="3" x2="12" y2="7" transform="rotate(30 12 12)"></line>
                    <line x1="12" y1="17" x2="12" y2="21" transform="rotate(30 12 12)"></line>
                    <line x1="12" y1="3" x2="12" y2="7" transform="rotate(60 12 12)"></line>
                    <line x1="12" y1="17" x2="12" y2="21" transform="rotate(60 12 12)"></line>
                    <line x1="12" y1="3" x2="12" y2="7" transform="rotate(90 12 12)"></line>
                    <line x1="12" y1="17" x2="12" y2="21" transform="rotate(90 12 12)"></line>
                    <line x1="12" y1="3" x2="12" y2="7" transform="rotate(120 12 12)"></line>
                    <line x1="12" y1="17" x2="12" y2="21" transform="rotate(120 12 12)"></line>
                    <line x1="12" y1="3" x2="12" y2="7" transform="rotate(150 12 12)"></line>
                    <line x1="12" y1="17" x2="12" y2="21" transform="rotate(150 12 12)"></line>
                </g>
            </svg>
        </div>

        <!-- Top Nav -->
        <nav class="flex flex-col items-center gap-1 w-full" id="sidebar-nav">
            <!-- Home (Active) -->
            <a href="#" class="nav-link relative flex justify-center w-full group py-1 active">
                <div class="nav-indicator absolute left-0 top-1/2 -translate-y-1/2 w-[3px] h-5 bg-[#a855f7] rounded-r-full transition-opacity opacity-100"></div>
                <div class="nav-icon-wrapper w-10 h-10 flex items-center justify-center bg-purple-50 text-[#a855f7] rounded-[10px] transition-colors">
                    <svg class="w-[20px] h-[20px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                </div>
            </a>
            
            <!-- Message -->
            <a href="#" class="nav-link relative flex justify-center w-full group py-1">
                <div class="nav-indicator absolute left-0 top-1/2 -translate-y-1/2 w-[3px] h-5 bg-[#a855f7] rounded-r-full transition-opacity opacity-0"></div>
                <div class="nav-icon-wrapper w-10 h-10 flex items-center justify-center text-zinc-500 bg-transparent rounded-[10px] group-hover:bg-zinc-100 group-hover:text-zinc-800 transition-colors">
                    <svg class="w-[20px] h-[20px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 11.99h.01M12 11.99h.01M16 11.99h.01M4 7c0-1.1.9-2 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-3.5l-4 4v-4H6a2 2 0 0 1-2-2V7z"></path></svg>
                </div>
            </a>
            <!-- History -->
            <a href="#" class="nav-link relative flex justify-center w-full group py-1">
                <div class="nav-indicator absolute left-0 top-1/2 -translate-y-1/2 w-[3px] h-5 bg-[#a855f7] rounded-r-full transition-opacity opacity-0"></div>
                <div class="nav-icon-wrapper w-10 h-10 flex items-center justify-center text-zinc-500 bg-transparent rounded-[10px] group-hover:bg-zinc-100 group-hover:text-zinc-800 transition-colors">
                    <svg class="w-[20px] h-[20px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 1 1-1.7-5.3L21 8m0 0V3m0 5h-5"></path></svg>
                </div>
            </a>
            <!-- Robot -->
            <a href="#" class="nav-link relative flex justify-center w-full group py-1">
                <div class="nav-indicator absolute left-0 top-1/2 -translate-y-1/2 w-[3px] h-5 bg-[#a855f7] rounded-r-full transition-opacity opacity-0"></div>
                <div class="nav-icon-wrapper w-10 h-10 flex items-center justify-center text-zinc-500 bg-transparent rounded-[10px] group-hover:bg-zinc-100 group-hover:text-zinc-800 transition-colors">
                    <svg class="w-[20px] h-[20px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 16h6m-7-5h.01M16 11h.01M6 8h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2zm-4 4h2m16 0h2m-11-7v2m2-2v2"></path></svg>
                </div>
            </a>
            <!-- Folder -->
            <a href="#" class="nav-link relative flex justify-center w-full group py-1">
                <div class="nav-indicator absolute left-0 top-1/2 -translate-y-1/2 w-[3px] h-5 bg-[#a855f7] rounded-r-full transition-opacity opacity-0"></div>
                <div class="nav-icon-wrapper w-10 h-10 flex items-center justify-center text-zinc-500 bg-transparent rounded-[10px] group-hover:bg-zinc-100 group-hover:text-zinc-800 transition-colors">
                    <svg class="w-[20px] h-[20px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path></svg>
                </div>
            </a>
            <!-- Share -->
            <a href="#" class="nav-link relative flex justify-center w-full group py-1">
                <div class="nav-indicator absolute left-0 top-1/2 -translate-y-1/2 w-[3px] h-5 bg-[#a855f7] rounded-r-full transition-opacity opacity-0"></div>
                <div class="nav-icon-wrapper w-10 h-10 flex items-center justify-center text-zinc-500 bg-transparent rounded-[10px] group-hover:bg-zinc-100 group-hover:text-zinc-800 transition-colors">
                    <svg class="w-[20px] h-[20px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path></svg>
                </div>
            </a>
            <!-- Database -->
            <a href="#" class="nav-link relative flex justify-center w-full group py-1">
                <div class="nav-indicator absolute left-0 top-1/2 -translate-y-1/2 w-[3px] h-5 bg-[#a855f7] rounded-r-full transition-opacity opacity-0"></div>
                <div class="nav-icon-wrapper w-10 h-10 flex items-center justify-center text-zinc-500 bg-transparent rounded-[10px] group-hover:bg-zinc-100 group-hover:text-zinc-800 transition-colors">
                    <svg class="w-[20px] h-[20px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path></svg>
                </div>
            </a>
        </nav>

        <!-- Bottom Nav -->
        <div class="flex flex-col items-center gap-1 mt-auto w-full" id="sidebar-bottom-nav">
            <!-- Headphones -->
            <a href="#" class="nav-link relative flex justify-center w-full group py-1">
                <div class="nav-indicator absolute left-0 top-1/2 -translate-y-1/2 w-[3px] h-5 bg-[#a855f7] rounded-r-full transition-opacity opacity-0"></div>
                <div class="nav-icon-wrapper w-10 h-10 flex items-center justify-center text-zinc-500 bg-transparent rounded-[10px] group-hover:bg-zinc-100 group-hover:text-zinc-800 transition-colors">
                    <svg class="w-[20px] h-[20px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 14v-4a9 9 0 0118 0v4m-18 0a2 2 0 002 2h2a2 2 0 002-2v-4a2 2 0 00-2-2H5m16 6a2 2 0 01-2 2h-2a2 2 0 01-2-2v-4a2 2 0 012-2h2"></path></svg>
                </div>
            </a>
            <!-- Gear -->
            <a href="#" class="nav-link relative flex justify-center w-full group py-1">
                <div class="nav-indicator absolute left-0 top-1/2 -translate-y-1/2 w-[3px] h-5 bg-[#a855f7] rounded-r-full transition-opacity opacity-0"></div>
                <div class="nav-icon-wrapper w-10 h-10 flex items-center justify-center text-zinc-500 bg-transparent rounded-[10px] group-hover:bg-zinc-100 group-hover:text-zinc-800 transition-colors">
                    <svg class="w-[20px] h-[20px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                </div>
            </a>
            
            <div class="mt-4 mb-2">
                <!-- Avatar Profile -->
                <div class="w-[30px] h-[30px] rounded-full overflow-hidden border border-zinc-200 cursor-pointer hover:opacity-80 transition-opacity">
                    <img src="https://i.pravatar.cc/150?img=11" alt="User Avatar" class="w-full h-full object-cover">
                </div>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col relative h-full">
        
        <!-- Header -->
        <header class="flex items-center justify-between px-8 py-4 w-full z-20 shrink-0">
            <!-- Left Model Selector -->
            <button class="flex items-center gap-1.5 px-3 py-1.5 bg-white rounded-[10px] border border-zinc-200/80 text-[13px] font-medium text-zinc-800 shadow-sm hover:bg-zinc-50 transition-colors">
                <svg class="w-3.5 h-3.5 text-zinc-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
                ChatGPT 4o
                <svg class="w-3.5 h-3.5 text-zinc-400 ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </button>

            <!-- Right Actions -->
            <div class="flex items-center gap-2.5">
                <div class="relative">
                    <svg class="w-4 h-4 text-zinc-600 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    <input type="text" placeholder="Search thread" class="pl-8 pr-4 py-1.5 w-44 bg-white rounded-[10px] text-[13px] outline-none text-zinc-800 placeholder-zinc-500 border border-zinc-200/80 focus:border-zinc-300 focus:ring-2 focus:ring-zinc-100 transition-all shadow-sm">
                </div>
                <button class="flex items-center gap-1.5 px-3 py-1.5 bg-white rounded-[10px] border border-zinc-200/80 text-[13px] font-medium text-zinc-800 shadow-sm hover:bg-zinc-50 transition-colors">
                    <svg class="w-4 h-4 text-zinc-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path></svg>
                    Invite
                </button>
                <button class="flex items-center gap-1.5 px-3 py-1.5 bg-[#18181b] rounded-[10px] text-[13px] font-medium text-white shadow-sm hover:bg-black transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"></path></svg>
                    New Thread
                </button>
            </div>
        </header>

        <!-- Center Content Body -->
        <div class="flex-1 flex flex-col items-center pt-[5vh] px-8 pb-10 w-full max-w-[800px] mx-auto z-10 overflow-y-auto">
            
            <!-- Floating Sphere -->
            <div class="relative mb-5">
                <!-- Outer Soft Glow -->
                <div class="absolute inset-0 bg-[#d8b4fe] blur-[40px] opacity-40 scale-[2] rounded-full transform translate-y-2"></div>
                <!-- Sphere Body -->
                <div class="w-[68px] h-[68px] rounded-full relative z-10 shadow-[0_12px_24px_-6px_rgba(168,85,247,0.4)]" style="background: radial-gradient(circle at 35% 25%, #f5d0fe 0%, #c084fc 40%, #7e22ce 100%);">
                    <!-- Bright top-left highlight -->
                    <div class="absolute top-1.5 left-2.5 w-7 h-3 rounded-full bg-white opacity-[0.65] blur-[1px] transform -rotate-[22deg]"></div>
                </div>
            </div>

            <!-- Greeting Text -->
            <div class="w-full text-center mb-8 relative z-10">
                <h1 class="text-[36px] font-medium text-[#18181b] tracking-[-0.02em] mb-1 leading-tight">Good Afternoon, Jason</h1>
                <p class="text-[36px] font-medium text-[#18181b] tracking-[-0.02em] leading-tight">What's on <span class="text-[#a855f7]">your mind?</span></p>
            </div>

            <!-- Chat Input Card -->
            <div class="w-full bg-white rounded-[20px] border border-zinc-200/80 shadow-[0_4px_24px_rgba(0,0,0,0.03)] flex flex-col relative z-10 mb-8">
                <div class="flex items-start px-4 pt-4 pb-[80px] w-full gap-2.5">
                    <svg class="w-4 h-4 text-zinc-800 mt-[3px] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
                    <textarea placeholder="Ask AI a question or make a request" class="w-full bg-transparent resize-none outline-none text-[#18181b] placeholder-zinc-500 text-[14px] py-0 font-sans" rows="1"></textarea>
                </div>
                
                <!-- Input Toolbar -->
                <div class="flex items-center justify-between px-3 pb-3">
                    <div class="flex gap-2">
                        <button class="flex items-center gap-1.5 px-3 py-1.5 rounded-[10px] bg-white transition-colors text-[13px] font-medium text-zinc-700 border border-zinc-200/80 hover:bg-zinc-50">
                            <svg class="w-3.5 h-3.5 text-zinc-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"></path></svg>
                            Attach
                        </button>
                        <div class="relative">
                            <button id="writing-styles-btn" class="flex items-center gap-1.5 px-3 py-1.5 rounded-[10px] bg-white transition-colors text-[13px] font-medium text-zinc-700 border border-zinc-200/80 hover:bg-zinc-50">
                                Writing Styles
                                <svg class="w-3.5 h-3.5 text-zinc-500 transition-transform duration-200" id="writing-styles-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path></svg>
                            </button>
                            
                            <!-- Dropdown Menu -->
                            <div id="writing-styles-dropdown" class="absolute left-0 bottom-[110%] mb-1 w-40 bg-white rounded-[12px] border border-zinc-200/80 shadow-[0_4px_24px_rgba(0,0,0,0.08)] py-1.5 opacity-0 invisible transition-all duration-200 origin-bottom-left scale-95 z-50">
                                <button class="w-full text-left px-3 py-1.5 text-[13px] text-zinc-700 hover:bg-zinc-50 transition-colors font-medium">Professional</button>
                                <button class="w-full text-left px-3 py-1.5 text-[13px] text-zinc-700 hover:bg-zinc-50 transition-colors font-medium">Casual</button>
                                <button class="w-full text-left px-3 py-1.5 text-[13px] text-zinc-700 hover:bg-zinc-50 transition-colors font-medium">Concise</button>
                            </div>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <label class="flex items-center gap-2 cursor-pointer text-[13px] font-medium text-zinc-700">
                            <div class="relative">
                                <input type="checkbox" class="sr-only peer" checked>
                                <div class="block w-[34px] h-[18px] rounded-full bg-zinc-200 peer-checked:bg-[#7e22ce] transition-colors duration-200"></div>
                                <div class="absolute left-[2px] top-[2px] bg-white w-[14px] h-[14px] rounded-full shadow-sm flex items-center justify-center transition-transform duration-200 peer-checked:translate-x-[16px]">
                                    <div class="w-1.5 h-1.5 rounded-full bg-[#7e22ce] opacity-0 peer-checked:opacity-100 transition-opacity duration-200"></div>
                                </div>
                            </div>
                            Citation
                        </label>
                        <button class="w-[30px] h-[30px] bg-[#18181b] rounded-full flex items-center justify-center text-white hover:bg-black transition-colors shadow-sm">
                            <svg class="w-[14px] h-[14px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path></svg>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Quick Start Cards -->
            <div class="w-full relative z-10">
                <p class="text-[11px] tracking-[0.08em] text-zinc-500 font-semibold mb-4 uppercase">Get started with an example below</p>
                <div class="grid grid-cols-4 gap-4">
                    <!-- Card 1 -->
                    <div class="bg-[#f7f7f9] rounded-[16px] h-[130px] w-full p-4 flex flex-col justify-between transition-colors hover:bg-zinc-100 cursor-pointer">
                        <p class="text-[13.5px] text-zinc-600 font-medium leading-snug">Write a to-do list for a personal project</p>
                        <svg class="w-4 h-4 text-zinc-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4" stroke-width="1.5"></circle></svg>
                    </div>
                    <!-- Card 2 -->
                    <div class="bg-[#f7f7f9] rounded-[16px] h-[130px] w-full p-4 flex flex-col justify-between transition-colors hover:bg-zinc-100 cursor-pointer">
                        <p class="text-[13.5px] text-zinc-600 font-medium leading-snug">Generate an email to reply to a job offer</p>
                        <svg class="w-4 h-4 text-zinc-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7.00005L10.2 11.65C11.2667 12.45 12.7333 12.45 13.8 11.65L20 7"></path><rect x="3" y="5" width="18" height="14" rx="2" stroke-width="1.5"></rect></svg>
                    </div>
                    <!-- Card 3 -->
                    <div class="bg-[#f7f7f9] rounded-[16px] h-[130px] w-full p-4 flex flex-col justify-between transition-colors hover:bg-zinc-100 cursor-pointer">
                        <p class="text-[13.5px] text-zinc-600 font-medium leading-snug">Summarize this article in one paragraph</p>
                        <svg class="w-4 h-4 text-zinc-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                    </div>
                    <!-- Card 4 -->
                    <div class="bg-[#f7f7f9] rounded-[16px] h-[130px] w-full p-4 flex flex-col justify-between transition-colors hover:bg-zinc-100 cursor-pointer">
                        <p class="text-[13.5px] text-zinc-600 font-medium leading-snug">How does AI work in a technical capacity</p>
                        <svg class="w-4 h-4 text-zinc-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" points="16 18 22 12 16 6"></polyline><polyline stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" points="8 6 2 12 8 18"></polyline></svg>
                    </div>
                </div>
            </div>

        </div>
    </main>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const navLinks = document.querySelectorAll('.nav-link');
        
        navLinks.forEach(link => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                
                // Reset all links
                navLinks.forEach(n => {
                    const indicator = n.querySelector('.nav-indicator');
                    if (indicator) {
                        indicator.classList.remove('opacity-100');
                        indicator.classList.add('opacity-0');
                    }
                    
                    const wrapper = n.querySelector('.nav-icon-wrapper');
                    if (wrapper) {
                        wrapper.className = 'nav-icon-wrapper w-10 h-10 flex items-center justify-center text-zinc-500 bg-transparent rounded-[10px] group-hover:bg-zinc-100 group-hover:text-zinc-800 transition-colors';
                    }
                });
                
                // Set active link
                const indicator = link.querySelector('.nav-indicator');
                if (indicator) {
                    indicator.classList.remove('opacity-0');
                    indicator.classList.add('opacity-100');
                }
                
                const wrapper = link.querySelector('.nav-icon-wrapper');
                if (wrapper) {
                    wrapper.className = 'nav-icon-wrapper w-10 h-10 flex items-center justify-center bg-purple-50 text-[#a855f7] rounded-[10px] transition-colors';
                }
            });
        });
        
        // Writing Styles Dropdown Logic
        const stylesBtn = document.getElementById('writing-styles-btn');
        const stylesDropdown = document.getElementById('writing-styles-dropdown');
        const stylesIcon = document.getElementById('writing-styles-icon');
        
        if (stylesBtn && stylesDropdown) {
            stylesBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                const isExpanded = !stylesDropdown.classList.contains('invisible');
                
                if (isExpanded) {
                    stylesDropdown.classList.add('invisible', 'opacity-0', 'scale-95');
                    stylesDropdown.classList.remove('opacity-100', 'scale-100');
                    stylesIcon.classList.remove('rotate-180');
                } else {
                    stylesDropdown.classList.remove('invisible', 'opacity-0', 'scale-95');
                    stylesDropdown.classList.add('opacity-100', 'scale-100');
                    stylesIcon.classList.add('rotate-180');
                }
            });
            
            // Close dropdown when clicking outside
            document.addEventListener('click', (e) => {
                if (!stylesBtn.contains(e.target) && !stylesDropdown.contains(e.target)) {
                    stylesDropdown.classList.add('invisible', 'opacity-0', 'scale-95');
                    stylesDropdown.classList.remove('opacity-100', 'scale-100');
                    stylesIcon.classList.remove('rotate-180');
                }
            });
            
            // Allow selecting a style
            const styleOptions = stylesDropdown.querySelectorAll('button');
            styleOptions.forEach(option => {
                option.addEventListener('click', (e) => {
                    // Just close it for now and maybe visually update the button text if needed
                    // (Keeping original text per request, just making it close)
                    stylesDropdown.classList.add('invisible', 'opacity-0', 'scale-95');
                    stylesDropdown.classList.remove('opacity-100', 'scale-100');
                    stylesIcon.classList.remove('rotate-180');
                });
            });
        }
    });
</script>
{% endblock %}
